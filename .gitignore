# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# server logs & temp outputs (local run artifacts)
*.log
tmp-*
/scripts/*.out

# env files (API keys - never commit)
.env*

# internal reference docs & fonts
/자료/
*.pdf
*.docx
*.ttf
*.otf
*.woff
*.woff2

# omc state (session-scoped, not shareable)
.omc/state/
.omc/sessions/
.omc/project-memory.json
.codex-push/

# vercel
.vercel

# session data (user-generated, persists locally)
/data/sessions/
/data/images/
/data/keyword-signal-cache.json
/data/keyword-result-cache.json

# shop reference photos (large binaries, kept local; index/profile/README tracked)
/data/shop-refs/**/*.jpg
/data/shop-refs/**/*.jpeg
/data/shop-refs/**/*.png
/data/shop-refs/**/*.webp

# local scratch artifacts
/.tmp-*
/.playwright-mcp/

# typescript
*.tsbuildinfo
next-env.d.ts
